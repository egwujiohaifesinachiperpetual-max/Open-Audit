# =============================================================================
# Open-Audit — Environment Variable Reference
# =============================================================================
#
# Copy this file to .env.local and fill in the values before starting the app:
#
#   cp .env.example .env.local
#
# Variables marked [REQUIRED] must be set for the application to start.
# Variables marked [OPTIONAL] can be left unset; defaults are shown and the
# feature they enable is described so you know what you will be missing.
#
# Variables prefixed with NEXT_PUBLIC_ are embedded in the browser bundle.
# Never put secrets in NEXT_PUBLIC_ variables.
# =============================================================================


# -----------------------------------------------------------------------------
# Stellar Network
# [REQUIRED for all deployments]
# -----------------------------------------------------------------------------

# Horizon REST API endpoint used by the event indexer and the frontend.
# Testnet:  https://horizon-testnet.stellar.org
# Mainnet:  https://horizon.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban JSON-RPC endpoint used to fetch contract events and submit
# transactions.
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://mainnet.stellar.validationcloud.io/v1/<YOUR_API_KEY>
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase — must exactly match the network you are connecting to.
# Testnet:  "Test SDF Network ; September 2015"
# Mainnet:  "Public Global Stellar Network ; September 2015"
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Human-readable network identifier consumed by the resilient RPC client.
# Accepted values: testnet | mainnet | futurenet
# Default: testnet
NEXT_PUBLIC_NETWORK=testnet

# [OPTIONAL] Fallback Soroban RPC URL used by the resilience layer when the
# primary endpoint (NEXT_PUBLIC_SOROBAN_RPC_URL) is unavailable or rate-
# limited. Useful for pointing at a locally running stellar/quickstart node
# during development.
# Default: http://localhost:8000/soroban/rpc
LOCAL_RPC_URL=http://localhost:8000/soroban/rpc


# -----------------------------------------------------------------------------
# Database — PostgreSQL / Prisma
# [REQUIRED when using database persistence or the microservices architecture]
# [OPTIONAL for basic local development with the in-memory mock data path]
# -----------------------------------------------------------------------------

# PostgreSQL connection string consumed by Prisma.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# For local development, create a database named open_audit:
#   createdb open_audit
# Then run migrations: npx prisma migrate dev
DATABASE_URL=postgresql://user:password@localhost:5432/open_audit


# -----------------------------------------------------------------------------
# Redis
# [OPTIONAL] — required only for the microservices / decoupled architecture
#              and for the translation cache.
#              The dashboard and basic indexing work without Redis.
# -----------------------------------------------------------------------------

# Redis connection URL.
# When this variable is unset Redis is disabled and the app falls back to an
# in-process memory cache (no persistence across restarts).
# Format: redis://<host>:<port>  or  rediss://<host>:<port>  (TLS)
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Redis Pub/Sub channel used by the indexer worker to publish events and by
# the web server to receive them.
# Only relevant when running the decoupled microservices architecture
# (npm run worker:indexer + npm run dev:decoupled).
# Default: stellar:events
REDIS_CHANNEL=stellar:events

# [OPTIONAL] TTL in seconds for translated-event entries stored in the Redis
# cache. After this period, stale entries are evicted and the next request
# re-translates from the raw XDR.
# Default: 3600 (1 hour)
REDIS_TTL_SECONDS=3600


# -----------------------------------------------------------------------------
# HTTP / WebSocket Server
# [OPTIONAL] — used by the legacy monolithic server (npm run dev:ws) and the
#              decoupled web server.
# -----------------------------------------------------------------------------

# TCP port the HTTP and WebSocket server listens on.
# Default: 3000
PORT=3000

# Maximum concurrent WebSocket connections allowed from a single IP address.
# Connections above this limit are rejected with code 1008.
# Increase this value if you are running multiple browser tabs in development
# or deploying behind a NAT where many users share one IP.
# Default: 5
MAX_WS_CONNECTIONS_PER_IP=5


# -----------------------------------------------------------------------------
# Indexer Worker
# [OPTIONAL] — these variables tune the standalone indexer worker
#              (src/worker/indexer.ts, started via npm run worker:indexer).
#              They have no effect when running the legacy monolithic server.
# -----------------------------------------------------------------------------

# Human-readable identifier for this worker instance.
# Useful when running multiple workers in parallel so log lines are
# distinguishable. Defaults to "worker-<PID>" when unset.
WORKER_ID=worker-1

# Indexing mode.
# stream — subscribes to Horizon's Server-Sent Events stream (recommended,
#           lower latency, pushes events as they are finalised).
# poll   — periodically polls the Soroban RPC for new events
#           (useful when your RPC node does not support streaming).
# Default: stream
INDEXER_MODE=stream

# Polling interval in milliseconds. Only used when INDEXER_MODE=poll.
# Default: 5000
POLL_INTERVAL_MS=5000

# Comma-separated list of Soroban contract IDs the indexer should watch.
# When unset the indexer listens to all contracts it discovers (broad mode).
# For local testing you can use the SAC contract for testnet USDC:
#   CCXVDIGMR6WTXZQX2OEVD6YM6AYCYPXPQ2VSN5NMAH5BNESE23OKBC2
# Leave blank for broad/all-contract mode.
CONTRACT_IDS=

# Enable the resilience layer (rate limiter + circuit breaker) for the
# polling RPC client. Set to "false" only for local testing against a node
# with no rate limits.
# Default: true  (set to "false" to disable)
ENABLE_RESILIENCE=true

# How often (milliseconds) the worker emits a health-check log line.
# Default: 30000 (30 seconds)
HEALTH_CHECK_INTERVAL_MS=30000


# -----------------------------------------------------------------------------
# Ingestion State & Ledger Cursor
# [OPTIONAL] — controls cold-start and captive-core behaviour.
# -----------------------------------------------------------------------------

# Path to the JSON file where the indexer persists its last-seen ledger
# sequence number between restarts. The file is created automatically on
# first run.
# Default: .open-audit/ingestion-state.json
INGESTION_STATE_FILE=.open-audit/ingestion-state.json

# How many ledgers to look back from the current ledger tip on a cold start
# (i.e., when no prior ingestion state exists).
# Larger values backfill more history but take longer on first run.
# Default: 100
INGESTION_COLD_START_LOOKBACK_LEDGERS=100

# Starting ledger sequence number for captive-core ingestion.
# Only used when STELLAR_CORE_BINARY is set.
# Set to 0 to start from the most recent checkpoint.
# Default: 0
INGESTION_START_LEDGER=0


# -----------------------------------------------------------------------------
# Stellar Captive Core  (advanced / high-throughput ingestion)
# [OPTIONAL] — leave these unset unless you are running a local Stellar Core
#              node for full-history or high-throughput indexing.
# -----------------------------------------------------------------------------

# Absolute path to the stellar-core binary.
# When unset, captive-core ingestion is disabled and the indexer falls back
# to polling via the Soroban RPC.
# Example: /usr/local/bin/stellar-core
STELLAR_CORE_BINARY=

# Transport protocol for the captive-core IPC channel.
# stdio — communicate over stdin/stdout (default, simplest setup).
# tcp   — communicate over a TCP socket (set STELLAR_CORE_STREAM_HOST and
#         STELLAR_CORE_STREAM_PORT as well).
# Default: stdio
STELLAR_CORE_TRANSPORT=stdio

# Host and port for captive-core TCP transport.
# Only used when STELLAR_CORE_TRANSPORT=tcp.
STELLAR_CORE_STREAM_HOST=127.0.0.1
STELLAR_CORE_STREAM_PORT=11625

# JSON object mapping archive names to Stellar history-archive URLs.
# Required for captive-core to validate and catch up to the network.
# Example (testnet):
#   STELLAR_HISTORY_ARCHIVES={"sdf_testnet":"https://history.stellar.org/prd/core-testnet/core_testnet_001"}
STELLAR_HISTORY_ARCHIVES=

# How long (milliseconds) to wait for a heartbeat from the captive-core
# process before treating it as unresponsive and triggering a restart.
# Default: 30000
STELLAR_CORE_HEARTBEAT_TIMEOUT_MS=30000

# Delay (milliseconds) between captive-core restart attempts after a crash.
# Default: 5000
STELLAR_CORE_RESTART_DELAY_MS=5000

# Maximum number of times the indexer will attempt to restart a failed
# captive-core process before giving up.
# Default: 2
STELLAR_CORE_MAX_RESTARTS=2


# -----------------------------------------------------------------------------
# Data Retention & Archival
# [OPTIONAL] — controls automatic pruning of the hot relational table.
#              Only relevant when DATABASE_URL is set.
# -----------------------------------------------------------------------------

# Number of days to keep Event rows in the hot PostgreSQL table.
# Events older than this are exported to a gzip-compressed CSV file
# (see ARCHIVE_OUTPUT_DIR) and then deleted from the database.
# Set to 0 to disable archival entirely.
# Default: 180
RETENTION_DAYS=180

# Cron expression that controls when the archive-and-purge job runs.
# Uses node-cron syntax: https://github.com/node-cron/node-cron#cron-syntax
# Default: "0 3 * * *"  (daily at 03:00 UTC)
RETENTION_CRON_SCHEDULE="0 3 * * *"

# Number of Event rows processed per database round-trip during archival.
# Larger batches are faster but consume more memory.
# Default: 1000
ARCHIVE_BATCH_SIZE=1000

# Directory where .csv.gz archive files are written.
# In production, mount a cold-storage volume or S3-compatible path here.
# Default: ./archives
ARCHIVE_OUTPUT_DIR=./archives


# -----------------------------------------------------------------------------
# IPFS  (large-event offloading)
# [OPTIONAL] — when set, event payloads larger than 2 KB are stored on IPFS
#              and a CID reference is broadcast instead, keeping WebSocket
#              messages small. Leave unset to disable IPFS offloading.
# -----------------------------------------------------------------------------

# URL for the local Kubo (go-ipfs) HTTP RPC API.
# Start a local node with: ipfs daemon
# Default: http://127.0.0.1:5001
IPFS_API_URL=http://127.0.0.1:5001

# IPFS HTTP Gateway URL used as a fallback for CID resolution by the
# frontend when the local API is unavailable.
# Default: http://127.0.0.1:8080
IPFS_GATEWAY_URL=http://127.0.0.1:8080


# -----------------------------------------------------------------------------
# API Key Authentication
# [OPTIONAL] — when unset all /api/v1/* routes are publicly accessible.
#              Set in production to require authenticated access.
# -----------------------------------------------------------------------------

# Comma-separated list of hashed API key entries in the format:
#   <hashedKey>:<tier>:<appName>
#
# To generate a key pair:
#   POST /api/developer/rotate-key  →  returns { key, hash, prefix }
# Copy the "hash" value into this variable; give the "key" value to the
# API consumer — it is never stored server-side.
#
# Tiers:
#   free    — 60 requests / minute
#   partner — 5 000 requests / minute
#
# Example:
#   OA_API_KEYS="abc123hash:free:my-wallet,def456hash:partner:analytics-bot"
OA_API_KEYS=


# -----------------------------------------------------------------------------
# Observability — Prometheus + OpenTelemetry / Jaeger
# [OPTIONAL] — telemetry is disabled when these variables are unset.
#              Prometheus metrics are always exposed at GET /metrics when
#              running npm run dev:ws regardless of these settings.
# -----------------------------------------------------------------------------

# Jaeger collector endpoint for OpenTelemetry trace export.
# When unset, tracing is disabled and no spans are exported.
# Default: http://localhost:14268/api/traces
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Service name attached to every OpenTelemetry span.
# Visible in Jaeger and other OTEL-compatible backends.
# Default: open-audit
OTEL_SERVICE_NAME=open-audit


# -----------------------------------------------------------------------------
# Error Monitoring — Sentry
# [OPTIONAL] — when unset, Sentry error reporting is disabled.
# -----------------------------------------------------------------------------

# Sentry DSN (Data Source Name) for production error grouping.
# Obtain this from your Sentry project settings → Client Keys.
# Errors are grouped by error type and contract address.
# Example: https://abc123@o000000.ingest.sentry.io/0000000
SENTRY_DSN=
