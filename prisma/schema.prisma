// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id              String   @id @unique
  contractId      String
  ledger          Int
  timestamp       Int
  txHash          String
  topics          Json     // Store as JSON array
  data            String   // Hex-encoded event data
  description     String?  // Translated human-readable text
  status          String   // "translated" | "cryptic"
  blueprintName   String?  // Contract name from blueprint
  eventType       String?  // Event type (transfer, mint, burn, etc.)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([contractId])
  @@index([ledger])
  @@index([txHash])
  @@index([contractId, ledger])
  @@index([timestamp])
}

model DeadLetterEvent {
  id            String   @id @default(cuid()) @unique
  eventId       String
  contractId    String
  ledger        Int
  timestamp     Int
  txHash        String
  topics        Json
  data          String
  errorCode     String
  errorMessage  String
  errorStack    String?
  errorContext  Json?
  createdAt     DateTime @default(now())

  @@index([contractId])
  @@index([eventId])
  @@index([createdAt])
}

// Tracks the indexer's progress through ledgers
model IndexerCursor {
  id              String   @id @default("current")
  lastLedger      Int      @default(0)
  lastProcessed   DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
